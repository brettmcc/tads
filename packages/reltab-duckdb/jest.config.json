{
  "transform": {
    "^.+\\.tsx?$": "ts-jest"
  },
  "testRegex": "/test/.*test.ts$",
  "testEnvironment": "node",
  "testPathIgnorePatterns": ["/node_modules/", "/__snapshots__", "ipfs.test.ts"],
  "moduleFileExtensions": ["ts", "js"],
  "testTimeout": 15000,
  "snapshotFormat": {
    "escapeString": true,
    "printBasicPrototype": true
  }
}
